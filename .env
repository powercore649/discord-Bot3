# ═══════════════════════════════════════════════════════════
#  Bumpify Dashboard — variables d'environnement (Vercel)
# ═══════════════════════════════════════════════════════════

# discord.com/developers/applications > votre app Bumpify > OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Générez avec : openssl rand -base64 32
NEXTAUTH_SECRET=

# URL publique du dashboard une fois déployé (sans slash final)
NEXTAUTH_URL=https://votre-projet.vercel.app

# Adresse de l'API pont qui tourne sur votre VPS
BRIDGE_URL=http://194.62.248.55:30024

# Doit être EXACTEMENT le même secret que DASHBOARD_API_SECRET côté bridge
BRIDGE_SECRET=

# Séparés par des virgules — IDs Discord autorisés à voir l'onglet "Premium"
# (mettre les mêmes IDs que OWNER_IDS du bot)
OWNER_IDS=
